<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <h1>Sistema de Carros</h1>
  <nav>
    <a href="/carros">Carros</a>
    <a href="/usuarios/cadastro">Cadastro</a>
    <a href="/usuarios/login">Login</a>
  </nav>
</header>
<div class="container">
  <div class="card">
    <h2>Login</h2>
    <% if (erro) { %><div class="alerta alerta-erro"><%= erro %></div><% } %>
    <form action="/usuarios/login" method="POST">
      <div class="form-group">
        <label>Login</label>
        <input type="text" name="login" required placeholder="Seu login">
      </div>
      <div class="form-group">
        <label>Senha</label>
        <input type="password" name="senha" required placeholder="Sua senha">
      </div>
      <button type="submit" class="btn btn-primary">Entrar</button>
    </form>
    <p style="text-align:center;margin-top:14px;color:#adb5bd;font-size:0.9rem">
      Não tem conta? <a href="/usuarios/cadastro" style="color:#e63946">Cadastrar-se</a>
    </p>
  </div>
</div>
</body>
</html>
