<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Carros Disponíveis</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <h1>Sistema de Carros</h1>
  <nav>
    <a href="/carros">Carros</a>
    <% if (usuario) { %>
      <a href="/carros/gerenciar">Gerenciar</a>
      <a href="/usuarios/logout" style="color:#e63946">Sair (<%= usuario %>)</a>
    <% } else { %>
      <a href="/usuarios/cadastro">Cadastro</a>
      <a href="/usuarios/login">Login</a>
    <% } %>
  </nav>
</header>

<div class="container">
  <h2 style="color:#e63946;margin-top:24px;">Carros Disponíveis</h2>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Marca</th><th>Modelo</th><th>Ano</th><th>Quantidade</th><th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (carros.length === 0) { %>
          <tr>
            <td colspan="5" style="text-align:center;color:#adb5bd;padding:20px">
              Nenhum carro cadastrado ainda.
            </td>
          </tr>
        <% } %>
        <% carros.forEach(function(carro) { %>
          <tr>
            <td><%= carro.marca %></td>
            <td><%= carro.modelo %></td>
            <td><%= carro.ano %></td>
            <td><%= carro.qtde_disponivel %></td>
            <td>
              <% if (carro.qtde_disponivel === 0) { %>
                <span class="badge-esgotado">ESGOTADO</span>
              <% } else { %>
                <span style="color:#2a9d5c;font-weight:bold;">Disponível</span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
</body>
</html>
