js// ANTES (Carros):
function atualizarCarro(id, marca, modelo, ano, qtde_disponivel) {
  const db = lerDB();
  const i = db.carros.findIndex(c => c.id === id);  // ← coleção
  if (i === -1) return { erro: 'Carro não encontrado.' };
  db.carros[i] = { ...db.carros[i], marca, modelo, ano: Number(ano), qtde_disponivel: Number(qtde_disponivel) };
  gravarDB(db);
  return { sucesso: true };
}

// DEPOIS (Livros):
function atualizarLivro(id, titulo, autor, ano, quantidade) {
  const db = lerDB();
  const i = db.livros.findIndex(l => l.id === id);  // ← coleção
  if (i === -1) return { erro: 'Livro não encontrado.' };
  db.livros[i] = { ...db.livros[i], titulo, autor, ano: Number(ano), quantidade: Number(quantidade) };
  gravarDB(db);
  return { sucesso: true };
}




js// ANTES (Carros):
function removerCarro(id) {
  const db = lerDB();
  db.carros = db.carros.filter(c => c.id !== id);  // ← coleção
  gravarDB(db);
  return { sucesso: true };
}

// DEPOIS (Livros):
function removerLivro(id) {
  const db = lerDB();
  db.livros = db.livros.filter(l => l.id !== id);  // ← coleção
  gravarDB(db);
  return { sucesso: true };
}




js// ANTES (Carros - Vender):
function venderCarro(id) {
  const db = lerDB();
  const i = db.carros.findIndex(c => c.id === id);
  if (i === -1) return { erro: 'Carro não encontrado.' };
  if (db.carros[i].qtde_disponivel <= 0) return { erro: 'Já esgotado.', esgotado: true };
  db.carros[i].qtde_disponivel -= 1;  // ← campo que decrementa
  gravarDB(db);
  return { sucesso: true, esgotado: db.carros[i].qtde_disponivel === 0, qtde: db.carros[i].qtde_disponivel };
}

// DEPOIS (Livros - Emprestar):
function emprestarLivro(id) {
  const db = lerDB();
  const i = db.livros.findIndex(l => l.id === id);
  if (i === -1) return { erro: 'Livro não encontrado.' };
  if (db.livros[i].quantidade <= 0) return { erro: 'Já esgotado.', esgotado: true };
  db.livros[i].quantidade -= 1;  // ← campo que decrementa
  gravarDB(db);
  return { sucesso: true, esgotado: db.livros[i].quantidade === 0, qtde: db.livros[i].quantidade };
}